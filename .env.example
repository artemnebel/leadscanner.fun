# ── Lead Scanner environment variables ─────────────────────────────────────
# Copy to .env.local for local dev (gitignored), and set the same keys in
# Render → your service → Environment for production. Never commit real values.

# Core
GOOGLE_MAPS_API_KEY=          # Google Places API key (required for scanning)
JWT_SECRET=                   # long random string used to sign login tokens
BASE_URL=http://localhost:8000  # your public URL in prod, e.g. https://leadscanner.fun
ADMIN_EMAIL=you@example.com   # this account is treated as admin + always Pro
# DATABASE_URL=               # set by Render (Postgres) in prod; omit locally to use sqlite

# Google sign-in (optional, only if using "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe ──────────────────────────────────────────────────────────────────
# Use TEST keys (sk_test_… / whsec_… from a test webhook) while validating,
# then swap to LIVE keys to go live.
STRIPE_SECRET_KEY=            # "Secret key" from Stripe → Developers → API keys (sk_live_… or sk_test_…)
STRIPE_WEBHOOK_SECRET=        # signing secret from Stripe → Developers → Webhooks → your endpoint (whsec_…)

# Pro plan price IDs — create two recurring Prices on ONE "Lead Scanner Pro"
# product in Stripe → Products, then paste their price_… IDs here.
STRIPE_PRICE_PRO_MONTHLY=     # $49 / month recurring price id
STRIPE_PRICE_PRO_ANNUAL=      # $490 / year recurring price id

# ── Legacy / dormant (safe to leave blank) ─────────────────────────────────
# Grandfathered subscription tiers + one-time credit packs. Not used by the
# current Free/Pro model, kept only so old subscribers keep working.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_UNLIMITED=
STRIPE_PRICE_PACK_MINI=
STRIPE_PRICE_PACK_STARTER=
STRIPE_PRICE_PACK_PRO=
STRIPE_PRICE_PACK_BUSINESS=
STRIPE_PRICE_PACK_BULK=
